# Python
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Data: large source CSVs and generated parquet (not tracked in git)
# (both loose in data/ and nested in subfolders like data/account_codes/)
data/*.csv
data/*.parquet
data/**/*.csv
data/**/*.parquet

# Exception: track curated, hand-maintainable crosswalks (small + diffable).
# The generated parquet stays ignored; the CSV is the tracked source of truth.
!data/crosswalks/
!data/crosswalks/*.csv

# Raw downloaded source archives / MS-Access databases (large, reproducible)
data/**/*.zip
data/**/*.mdb
data/**/*.accdb
data/**/*.doc
data/**/*.docx

# Source spreadsheets & report PDFs (large, reproducible downloads from NYSED)
data/**/*.xls
data/**/*.xlsx
data/**/*.xlsm
data/**/*.pdf

# Quarto
/.quarto/
/_book/
/_site/
# rendered books & quarto caches live in each book dir (e.g. books/*/_book/)
**/_book/
**/.quarto/
**/_freeze/
# standalone rendered HTML at repo root (e.g. nys_contingency_budgets.html)
/*.html

# OS / editor
.DS_Store
.Rproj.user/
.Rhistory

**/*.quarto_ipynb
