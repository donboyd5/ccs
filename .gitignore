# Python
.venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Data (see data/README.md for the raw/ vs processed/ scheme).
# Raw source files under data/raw/<source>/ and all generated parquet/CSV are
# NOT tracked; provenance lives in tracked .md files (SOURCE.md / README.md),
# which are never matched by these data patterns.
data/*.csv
data/*.parquet
data/**/*.csv
data/**/*.parquet

# Exception: track curated, hand-maintainable crosswalks (small + diffable).
# The generated parquet stays ignored; the CSV is the tracked source of truth.
!data/crosswalks/
!data/crosswalks/*.csv

# Raw downloaded source archives / MS-Access databases (large, reproducible)
data/**/*.zip
data/**/*.mdb
data/**/*.accdb
data/**/*.doc
data/**/*.docx

# Source spreadsheets & report PDFs (large, reproducible downloads from NYSED)
data/**/*.xls
data/**/*.xlsx
data/**/*.xlsm
data/**/*.pdf

# Quarto
/.quarto/
/_book/
/_site/
# rendered books & quarto caches live in each book dir (e.g. books/*/_book/)
**/_book/
**/.quarto/
**/_freeze/
# standalone rendered HTML at repo root (e.g. nys_contingency_budgets.html)
/*.html

# OS / editor
.DS_Store
.Rproj.user/
.Rhistory

**/*.quarto_ipynb
